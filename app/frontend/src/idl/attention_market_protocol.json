  "types": [
    {
      "name": "Bet",
      "docs": [
        "A user's stake on a specific market outcome."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "market",
            "docs": [
              "Market this bet belongs to."
            ],
            "type": "pubkey"
          },
          {
            "name": "user",
            "docs": [
              "Bettor wallet."
            ],
            "type": "pubkey"
          },
          {
            "name": "side",
            "docs": [
              "Predicted side (Over or Under the engagement threshold)."
            ],
            "type": {
              "defined": {
                "name": "BetSide"
              }
            }
          },
          {
            "name": "amount",
            "docs": [
              "Lamports staked on this bet."
            ],
            "type": "u64"
          },
          {
            "name": "claimed",
            "docs": [
              "Whether winnings have been claimed."
            ],
            "type": "bool"
          },
          {
            "name": "bump",
            "docs": [
              "Bump for the bet PDA."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "BetSide",
      "docs": [
        "Which side of the engagement threshold bettors can take."
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Over"
          },
          {
            "name": "Under"
          }
        ]
      }
    },
    {
      "name": "Config",
      "docs": [
        "Global protocol configuration. One instance per deployment."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "Protocol administrator allowed to settle markets."
            ],
            "type": "pubkey"
          },
          {
            "name": "fee_bps",
            "docs": [
              "Protocol fee taken from the losing pool on settlement, in basis points."
            ],
            "type": "u16"
          },
          {
            "name": "total_markets",
            "docs": [
              "Total number of markets created."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "Bump for the config PDA."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "Market",
      "docs": [
        "A prediction market for a single piece of short-form content."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "creator",
            "docs": [
              "Creator of this market."
            ],
            "type": "pubkey"
          },
          {
            "name": "platform",
            "docs": [
              "Platform the content lives on."
            ],
            "type": {
              "defined": {
                "name": "Platform"
              }
            }
          },
          {
            "name": "content_id",
            "docs": [
              "Unique content identifier (URL hash, post ID, etc.)."
            ],
            "type": "string"
          },
          {
            "name": "engagement_threshold",
            "docs": [
              "Engagement target (views, likes, etc.) bettors predict over/under."
            ],
            "type": "u64"
          },
          {
            "name": "deadline",
            "docs": [
              "Unix timestamp after which no new bets are accepted."
            ],
            "type": "i64"
          },
          {
            "name": "total_over",
            "docs": [
              "Total lamports staked on the Over side."
            ],
            "type": "u64"
          },
          {
            "name": "total_under",
            "docs": [
              "Total lamports staked on the Under side."
            ],
            "type": "u64"
          },
          {
            "name": "status",
            "docs": [
              "Current market status."
            ],
            "type": {
              "defined": {
                "name": "MarketStatus"
              }
            }
          },
          {
            "name": "outcome",
            "docs": [
              "Winning side, set during settlement."
            ],
            "type": {
              "option": {
                "defined": {
                  "name": "BetSide"
                }
              }
            }
          },
          {
            "name": "final_engagement",
            "docs": [
              "Observed engagement at settlement time."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "Bump for the market PDA."
            ],
            "type": "u8"
          },
          {
            "name": "vault_bump",
            "docs": [
              "Bump for the vault PDA holding staked lamports."
            ],
            "type": "u8"
          }
        ]
      }
    },
