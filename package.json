{
  "name": "attention-market-protocol",
  "license": "ISC",
  "scripts": {
    "test:anchor": "ts-mocha -p ./tsconfig.json -t 1000000 \"tests/**/*.ts\"",
    "test:devnet": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com anchor test --skip-local-validator --provider.cluster devnet",
    "test:happy": "anchor test",
    "deploy:devnet": "anchor build && anchor deploy --provider.cluster devnet",
    "seed:demo": "ts-mocha -p ./tsconfig.json -t 60000 scripts/seed-demo-markets.ts",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^5.7.3",
    "prettier": "^2.6.2"
  }
}
